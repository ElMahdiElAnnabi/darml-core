# --- Server ----------------------------------------------------------
DARML_HOST=0.0.0.0
DARML_PORT=8080
DARML_PUBLIC_BASE_URL=http://localhost:8080

# --- Storage ---------------------------------------------------------
DARML_DATA_DIR=./data
DARML_MAX_MODEL_SIZE_MB=100
DARML_BUILD_TIMEOUT=300

# Persistence — set true to use SQLite, false for in-memory.
DARML_USE_SQLITE=false
DARML_SQLITE_PATH=./data/darml.db

# --- Build cache -----------------------------------------------------
DARML_CACHE_ENABLED=true
DARML_CACHE_DIR=./data/cache

# --- CORS ------------------------------------------------------------
# Comma-separated list of allowed origins; * for any.
DARML_CORS_ORIGINS=*

# --- Toolchain -------------------------------------------------------
DARML_PLATFORMIO_PATH=pio

# --- Auth + rate limiting -------------------------------------------
# When false, every caller is treated as anonymous Pro (no header needed).
# Flip to true on hosted deployments and seed DARML_API_KEYS.
DARML_AUTH_ENABLED=false
DARML_FREE_TIER_DAILY_QUOTA=5
# Format: "<secret>:<tier>[:<label>]", comma-separated.
# Example: DARML_API_KEYS=sk_pro_acme:pro:acme,sk_free_demo:free:demo
DARML_API_KEYS=

# --- Stripe ----------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_CLOUD=
STRIPE_PRICE_PRO_SELFHOST=

# --- Sentry ----------------------------------------------------------
SENTRY_DSN=

# --- Logging --------------------------------------------------------
DARML_DEBUG=false
